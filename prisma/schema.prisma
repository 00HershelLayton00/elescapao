generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  points    Int      @default(0)
  role      String   @default("USER")
  orders    Order[]
  createdAt DateTime @default(now())
}

model Order {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  items       String
  total       Float
  status      String   @default("PENDING")
  paymentType String
  createdAt   DateTime @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  category    String
  isAvailable Boolean  @default(true)
}
